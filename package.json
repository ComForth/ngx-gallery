    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.1",
    "@angular/router": "^19.2.1",
    "font-awesome": "^4.7.0",
    "hammerjs": "^2.0.8",
    "karma-viewport": "^1.0.9",
    "tslib": "^2.3.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.1",
    "@angular-eslint/builder": "^19.2.0",
